# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=+14155238886        # Twilio sandbox number (or your business number)
OWNER_WHATSAPP_NUMBER=+1xxxxxxxxxx       # Your personal WhatsApp number (E.164 format)

# Google Sheets
GOOGLE_CREDENTIALS_PATH=credentials.json
SPREADSHEET_ID=                          # Fill after running: python tools/setup_sheets.py

# Server
PORT=5001
FLASK_ENV=development                    # Change to 'production' when deployed
